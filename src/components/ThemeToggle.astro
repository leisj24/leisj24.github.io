---
---

<button id="theme-toggle" type="button" aria-label="切换深色 / 浅色模式">
	<svg class="icon icon-sun" viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
		<circle cx="12" cy="12" r="4" fill="currentColor"></circle>
		<g stroke="currentColor" stroke-width="2" stroke-linecap="round">
			<line x1="12" y1="2" x2="12" y2="5"></line>
			<line x1="12" y1="19" x2="12" y2="22"></line>
			<line x1="2" y1="12" x2="5" y2="12"></line>
			<line x1="19" y1="12" x2="22" y2="12"></line>
			<line x1="4.5" y1="4.5" x2="6.6" y2="6.6"></line>
			<line x1="17.4" y1="17.4" x2="19.5" y2="19.5"></line>
			<line x1="4.5" y1="19.5" x2="6.6" y2="17.4"></line>
			<line x1="17.4" y1="6.6" x2="19.5" y2="4.5"></line>
		</g>
	</svg>
	<svg class="icon icon-moon" viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
		<path
			d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"
			fill="currentColor"></path>
	</svg>
</button>

<style>
	#theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 38px;
		height: 38px;
		padding: 0;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-pill);
		background: var(--color-surface);
		color: var(--color-text);
		cursor: pointer;
		transition:
			background 200ms ease,
			color 200ms ease,
			border-color 200ms ease,
			transform 200ms ease;
	}
	#theme-toggle:hover {
		color: var(--color-accent);
		border-color: var(--color-accent);
		transform: rotate(-15deg);
	}
	.icon-moon {
		display: none;
	}
	:root[data-theme='dark'] .icon-sun {
		display: none;
	}
	:root[data-theme='dark'] .icon-moon {
		display: inline-block;
	}
</style>

<script is:inline>
	document.addEventListener('astro:page-load', () => {
		const btn = document.getElementById('theme-toggle');
		if (!btn || btn.dataset.bound) return;
		btn.dataset.bound = '1';
		btn.addEventListener('click', () => {
			const next =
				document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
			document.documentElement.dataset.theme = next;
			try {
				localStorage.setItem('theme', next);
			} catch (e) {
				/* localStorage unavailable */
			}
		});
	});
</script>
