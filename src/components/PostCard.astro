---
import FormattedDate from './FormattedDate.astro';
import { formatWordCount } from '../utils/reading-time';

interface Props {
	href: string;
	title: string;
	pubDate: Date;
	description?: string;
	tags?: string[];
	words?: number;
	minutes?: number;
}

const { href, title, pubDate, description, tags, words, minutes } = Astro.props;
---

<a class="card" href={href}>
	<h3 class="title">{title}</h3>
	<div class="meta">
		<span class="meta-item">
			<svg viewBox="0 0 24 24" aria-hidden="true" width="13" height="13">
				<path
					fill="currentColor"
					d="M19 4h-1V2h-2v2H8V2H6v2H5C3.9 4 3 4.9 3 6v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2Zm0 16H5V10h14v10Zm0-12H5V6h14v2Z"
				></path>
			</svg>
			<FormattedDate date={pubDate} />
		</span>
		{
			words !== undefined && (
				<span class="meta-item">
					<svg viewBox="0 0 24 24" aria-hidden="true" width="13" height="13">
						<path
							fill="currentColor"
							d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6Zm-1 7V3.5L18.5 9H13Z"
						/>
					</svg>
					{formatWordCount(words)}
				</span>
			)
		}
		{
			minutes !== undefined && (
				<span class="meta-item">
					<svg viewBox="0 0 24 24" aria-hidden="true" width="13" height="13">
						<path
							fill="currentColor"
							d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8Zm.5-13H11v6l5.2 3.1.8-1.3-4.5-2.7Z"
						/>
					</svg>
					{minutes} 分钟
				</span>
			)
		}
	</div>
	{description && <p class="excerpt">{description}</p>}
	{
		tags && tags.length > 0 && (
			<div class="tags">
				{tags.map((tag) => (
					<span class="tag">{tag}</span>
				))}
			</div>
		)
	}
</a>

<style>
	.card {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		padding: 1.4rem 1.5rem 1.25rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-card);
		box-shadow: var(--shadow-card);
		color: var(--color-text);
		text-decoration: none;
		transition:
			transform 240ms ease,
			border-color 240ms ease,
			box-shadow 240ms ease;
		height: 100%;
	}
	.card:hover {
		transform: translateY(-3px);
		border-color: var(--color-accent);
		box-shadow: var(--shadow-card-hover);
	}
	.title {
		margin: 0;
		font-size: 1.2rem;
		font-weight: 700;
		line-height: 1.4;
		color: var(--color-text);
		transition: color 200ms ease;
	}
	.card:hover .title {
		color: var(--color-accent);
	}
	.meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 0.85rem;
		color: var(--color-text-muted);
		font-size: 0.82rem;
	}
	.meta-item {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
	}
	.excerpt {
		margin: 0.1rem 0 0;
		color: var(--color-text-muted);
		font-size: 0.95rem;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		margin-top: auto;
		padding-top: 0.5rem;
	}
	.tag {
		display: inline-flex;
		align-items: center;
		padding: 0.15rem 0.6rem;
		background: color-mix(in srgb, var(--color-accent-soft) 30%, transparent);
		color: var(--color-accent);
		border-radius: var(--radius-pill);
		font-size: 0.75rem;
		font-weight: 500;
	}
	.card:hover .tag {
		background: color-mix(in srgb, var(--color-accent-soft) 50%, transparent);
	}
</style>
