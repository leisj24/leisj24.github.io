---
import FormattedDate from './FormattedDate.astro';

interface Props {
	href: string;
	title: string;
	pubDate: Date;
	description?: string;
}

const { href, title, pubDate, description } = Astro.props;
---

<a class="card" href={href}>
	<h3 class="title">{title}</h3>
	<p class="meta">
		<svg viewBox="0 0 24 24" aria-hidden="true" width="14" height="14">
			<path
				fill="currentColor"
				d="M19 4h-1V2h-2v2H8V2H6v2H5C3.9 4 3 4.9 3 6v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2Zm0 16H5V10h14v10Zm0-12H5V6h14v2Z"
			></path>
		</svg>
		<FormattedDate date={pubDate} />
	</p>
	{description && <p class="excerpt">{description}</p>}
	<span class="read-more">阅读 →</span>
</a>

<style>
	.card {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 1.4rem 1.5rem 1.25rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-card);
		box-shadow: var(--shadow-card);
		color: var(--color-text);
		text-decoration: none;
		transition:
			transform 240ms ease,
			border-color 240ms ease,
			box-shadow 240ms ease;
		height: 100%;
	}
	.card:hover {
		transform: translateY(-3px);
		border-color: var(--color-accent);
		box-shadow: var(--shadow-card-hover);
	}
	.title {
		margin: 0;
		font-size: 1.2rem;
		font-weight: 700;
		line-height: 1.35;
		color: var(--color-text);
		transition: color 200ms ease;
	}
	.card:hover .title {
		color: var(--color-accent);
	}
	.meta {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		margin: 0;
		color: var(--color-text-muted);
		font-size: 0.85rem;
	}
	.excerpt {
		margin: 0.25rem 0 0;
		color: var(--color-text-muted);
		font-size: 0.95rem;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.read-more {
		margin-top: auto;
		padding-top: 0.5rem;
		color: var(--color-accent);
		font-size: 0.9rem;
		font-weight: 500;
		opacity: 0;
		transform: translateX(-4px);
		transition:
			opacity 240ms ease,
			transform 240ms ease;
	}
	.card:hover .read-more {
		opacity: 1;
		transform: translateX(0);
	}
</style>
