---
interface Props {
	name: string;
	tagline: string;
}

const { name, tagline } = Astro.props;
---

<section class="hero">
	<div class="avatar-wrap">
		<img src="/avatar.png" alt={name} width="120" height="120" loading="eager" />
	</div>
	<h1 class="name">{name}</h1>
	<p class="tagline">{tagline}</p>
	<div class="socials">
		<a class="pill" href="https://github.com/leisj24" target="_blank" rel="noopener" aria-label="GitHub">
			<svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16">
				<path
					fill="currentColor"
					d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
				></path>
			</svg>
			<span>GitHub</span>
		</a>
		<a
			class="pill js-mail"
			href="#"
			data-u="sjlei24"
			data-d="mail.ustc.edu.cn"
			aria-label="Email"
		>
			<svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16">
				<path
					fill="currentColor"
					d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 4-8 5-8-5V6l8 5 8-5v2Z"
				></path>
			</svg>
			<span>Email</span>
		</a>
	</div>
</section>

<style>
	.hero {
		position: relative;
		max-width: 680px;
		margin: 1.5rem auto 3rem;
		padding: 2.75rem 1.5rem 2.25rem;
		text-align: center;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-card);
		box-shadow: var(--shadow-card);
		overflow: hidden;
	}
	.hero::before {
		content: '';
		position: absolute;
		inset: -40% -20% auto -20%;
		height: 240px;
		background: radial-gradient(
				ellipse at 30% 30%,
				color-mix(in srgb, var(--color-accent-soft) 55%, transparent),
				transparent 60%
			),
			radial-gradient(
				ellipse at 70% 40%,
				color-mix(in srgb, var(--color-accent-hover) 35%, transparent),
				transparent 65%
			);
		pointer-events: none;
		z-index: 0;
	}
	.hero > * {
		position: relative;
		z-index: 1;
	}
	.avatar-wrap {
		display: inline-block;
		padding: 4px;
		background: linear-gradient(
			135deg,
			var(--color-accent),
			var(--color-accent-hover)
		);
		border-radius: var(--radius-pill);
		box-shadow: 0 8px 24px
			color-mix(in srgb, var(--color-accent) 35%, transparent);
	}
	.avatar-wrap img {
		display: block;
		width: 120px;
		height: 120px;
		border-radius: var(--radius-pill);
		object-fit: cover;
		background: var(--color-surface);
	}
	.name {
		margin: 1rem 0 0.25rem;
		font-size: 2.1rem;
		font-weight: 700;
		letter-spacing: -0.02em;
	}
	.tagline {
		margin: 0 0 1.5rem;
		color: var(--color-text-muted);
		font-style: italic;
		font-size: 1.05rem;
	}
	.socials {
		display: flex;
		justify-content: center;
		gap: 0.6rem;
		flex-wrap: wrap;
	}
	.pill {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.45rem 1rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-pill);
		background: var(--color-surface);
		color: var(--color-text);
		font-size: 0.92rem;
		font-weight: 500;
		text-decoration: none;
		transition:
			border-color 200ms ease,
			color 200ms ease,
			transform 200ms ease,
			background 200ms ease;
	}
	.pill:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
		transform: translateY(-1px);
	}

	@media (max-width: 720px) {
		.hero {
			padding: 2rem 1rem 1.75rem;
		}
		.name {
			font-size: 1.7rem;
		}
		.avatar-wrap img {
			width: 96px;
			height: 96px;
		}
	}
</style>

<script is:inline>
	document.querySelectorAll('.js-mail').forEach((el) => {
		el.addEventListener('click', (e) => {
			e.preventDefault();
			const u = el.dataset.u;
			const d = el.dataset.d;
			if (u && d) window.location.href = 'mailto:' + u + '@' + d;
		});
	});
</script>
