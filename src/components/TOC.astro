---
import type { MarkdownHeading } from 'astro';

interface Props {
	headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{
	tocHeadings.length > 0 && (
		<nav class="toc" aria-label="目录">
			<p class="toc-title">目录</p>
			<ul>
				{tocHeadings.map((h) => (
					<li class={`toc-item toc-depth-${h.depth}`}>
						<a href={`#${h.slug}`} data-toc-link={h.slug}>
							{h.text}
						</a>
					</li>
				))}
			</ul>
		</nav>
	)
}

<style>
	.toc {
		position: sticky;
		top: 5rem;
		padding: 1.25rem 1.25rem 1.5rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-card);
		box-shadow: var(--shadow-card);
		max-height: calc(100vh - 7rem);
		overflow-y: auto;
	}
	.toc-title {
		margin: 0 0 0.75rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}
	.toc ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.toc-item {
		position: relative;
		margin: 0;
	}
	.toc-item a {
		display: block;
		padding: 0.35rem 0.5rem 0.35rem 0.75rem;
		color: var(--color-text-muted);
		font-size: 0.88rem;
		line-height: 1.4;
		text-decoration: none;
		border-left: 2px solid transparent;
		border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
		transition:
			color 180ms ease,
			border-color 180ms ease,
			background 180ms ease;
	}
	.toc-depth-3 a {
		padding-left: 1.75rem;
		font-size: 0.82rem;
	}
	.toc-item a:hover {
		color: var(--color-accent);
		background: color-mix(in srgb, var(--color-accent-soft) 18%, transparent);
	}
	.toc-item a.is-active {
		color: var(--color-accent);
		border-left-color: var(--color-accent);
		font-weight: 600;
		background: color-mix(in srgb, var(--color-accent-soft) 20%, transparent);
	}
	.toc::-webkit-scrollbar {
		width: 4px;
	}
	.toc::-webkit-scrollbar-thumb {
		background: var(--color-border);
		border-radius: 4px;
	}
</style>

<script>
	let observer: IntersectionObserver | null = null;

	function initTOC() {
		observer?.disconnect();
		observer = null;

		const links = Array.from(
			document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'),
		);
		if (links.length === 0) return;

		const targets = links
			.map((link) => {
				const slug = link.dataset.tocLink!;
				const el = document.getElementById(slug);
				return el ? { link, el } : null;
			})
			.filter((x): x is { link: HTMLAnchorElement; el: HTMLElement } => x !== null);

		if (targets.length === 0) return;

		const setActive = (slug: string) => {
			links.forEach((l) => {
				l.classList.toggle('is-active', l.dataset.tocLink === slug);
			});
		};

		observer = new IntersectionObserver(
			(entries) => {
				const visible = entries
					.filter((e) => e.isIntersecting)
					.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
				if (visible.length > 0) {
					setActive(visible[0].target.id);
				}
			},
			{
				rootMargin: '-80px 0px -70% 0px',
				threshold: 0,
			},
		);

		targets.forEach(({ el }) => observer!.observe(el));

		links.forEach((link) => {
			if (link.dataset.bound) return;
			link.dataset.bound = '1';
			link.addEventListener('click', (e) => {
				const slug = link.dataset.tocLink;
				if (!slug) return;
				const el = document.getElementById(slug);
				if (!el) return;
				e.preventDefault();
				const top = el.getBoundingClientRect().top + window.scrollY - 80;
				window.scrollTo({ top, behavior: 'smooth' });
				history.replaceState(null, '', `#${slug}`);
			});
		});
	}

	document.addEventListener('astro:page-load', initTOC);
	document.addEventListener('astro:before-swap', () => {
		observer?.disconnect();
		observer = null;
	});
</script>
