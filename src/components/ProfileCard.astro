---
interface Props {
	name: string;
	tagline: string;
}

const { name, tagline } = Astro.props;
---

<aside class="profile-card">
	<div class="avatar-wrap">
		<img src="/avatar.png" alt={name} width="96" height="96" loading="eager" />
	</div>
	<h3 class="name">{name}</h3>
	<p class="tagline">{tagline}</p>
	<div class="socials">
		<a
			class="pill"
			href="https://github.com/leisj24"
			target="_blank"
			rel="noopener"
			aria-label="GitHub"
		>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="14" height="14">
				<path
					fill="currentColor"
					d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
				></path>
			</svg>
			<span>GitHub</span>
		</a>
		<a
			class="pill js-mail"
			href="#"
			data-u="sjlei24"
			data-d="mail.ustc.edu.cn"
			aria-label="Email"
		>
			<svg viewBox="0 0 24 24" aria-hidden="true" width="14" height="14">
				<path
					fill="currentColor"
					d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 4-8 5-8-5V6l8 5 8-5v2Z"
				></path>
			</svg>
			<span>Email</span>
		</a>
	</div>
</aside>

<style>
	.profile-card {
		position: relative;
		padding: 1.75rem 1.25rem 1.5rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-card);
		box-shadow: var(--shadow-card);
		text-align: center;
		overflow: hidden;
	}
	.profile-card::before {
		content: '';
		position: absolute;
		inset: -50% -20% auto -20%;
		height: 160px;
		background: radial-gradient(
				ellipse at 30% 30%,
				color-mix(in srgb, var(--color-accent-soft) 50%, transparent),
				transparent 60%
			),
			radial-gradient(
				ellipse at 70% 40%,
				color-mix(in srgb, var(--color-accent-hover) 30%, transparent),
				transparent 65%
			);
		pointer-events: none;
		z-index: 0;
	}
	.profile-card > * {
		position: relative;
		z-index: 1;
	}
	.avatar-wrap {
		display: inline-block;
		padding: 3px;
		background: linear-gradient(
			135deg,
			var(--color-accent),
			var(--color-accent-hover)
		);
		border-radius: var(--radius-pill);
		box-shadow: 0 6px 18px
			color-mix(in srgb, var(--color-accent) 30%, transparent);
	}
	.avatar-wrap img {
		display: block;
		width: 96px;
		height: 96px;
		border-radius: var(--radius-pill);
		object-fit: cover;
		background: var(--color-surface);
	}
	.name {
		margin: 0.85rem 0 0.25rem;
		font-size: 1.25rem;
		font-weight: 700;
		letter-spacing: -0.01em;
	}
	.tagline {
		margin: 0 0 1.1rem;
		color: var(--color-text-muted);
		font-style: italic;
		font-size: 0.88rem;
		line-height: 1.5;
	}
	.socials {
		display: flex;
		justify-content: center;
		gap: 0.5rem;
		flex-wrap: wrap;
	}
	.pill {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.35rem 0.8rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-pill);
		background: var(--color-surface);
		color: var(--color-text);
		font-size: 0.82rem;
		font-weight: 500;
		text-decoration: none;
		transition:
			border-color 200ms ease,
			color 200ms ease,
			transform 200ms ease;
	}
	.pill:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
		transform: translateY(-1px);
	}
</style>

<script is:inline>
	document.addEventListener('astro:page-load', () => {
		document.querySelectorAll('.js-mail').forEach((el) => {
			if (el.dataset.bound) return;
			el.dataset.bound = '1';
			el.addEventListener('click', (e) => {
				e.preventDefault();
				const u = el.dataset.u;
				const d = el.dataset.d;
				if (u && d) window.location.href = 'mailto:' + u + '@' + d;
			});
		});
	});
</script>
