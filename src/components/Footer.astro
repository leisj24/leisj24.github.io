---
const today = new Date();
---

<footer>
	<div class="inner">
		<span>&copy; {today.getFullYear()} leisj24</span>
		<span class="dot">·</span>
		<span>
			Built with
			<a href="https://astro.build/" target="_blank" rel="noopener">Astro</a>
		</span>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--color-border);
		background: var(--color-bg);
		color: var(--color-text-muted);
		padding: 1.5rem 1rem;
		text-align: center;
		font-size: 0.9rem;
	}
	.inner {
		max-width: 1080px;
		margin: 0 auto;
		display: inline-flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		justify-content: center;
	}
	footer a {
		color: var(--color-text);
		font-weight: 500;
	}
	footer a:hover {
		color: var(--color-accent);
	}
	.dot {
		opacity: 0.6;
	}
</style>
