---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import Banner from '../components/Banner.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TOC from '../components/TOC.astro';
import { SITE_TITLE } from '../consts';
import { formatWordCount, type ReadingStats } from '../utils/reading-time';

interface Props extends CollectionEntry<'blog'>['data'] {
	headings?: MarkdownHeading[];
	stats?: ReadingStats;
}

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags,
	headings = [],
	stats,
} = Astro.props;

const bannerImage = heroImage?.src ?? '/banner.jpg';
const hasTOC = headings.some((h) => h.depth >= 2 && h.depth <= 3);
---

<html lang="zh-CN">
	<head>
		<BaseHead title={`${title} · ${SITE_TITLE}`} description={description} />
	</head>
	<body>
		<Header />
		<Banner image={bannerImage} title={title} subtitle={description} height="medium" />
		<main class:list={[{ 'has-toc': hasTOC }]}>
			<div class="article-with-toc">
				<article>
					<header class="post-head">
						<div class="meta">
							<span class="meta-item">
								<svg viewBox="0 0 24 24" aria-hidden="true" width="14" height="14"><path fill="currentColor" d="M19 4h-1V2h-2v2H8V2H6v2H5C3.9 4 3 4.9 3 6v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2Zm0 16H5V10h14v10Zm0-12H5V6h14v2Z"/></svg>
								<FormattedDate date={pubDate} />
							</span>
							{stats && (
								<span class="meta-item">
									<svg viewBox="0 0 24 24" aria-hidden="true" width="14" height="14"><path fill="currentColor" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6Zm-1 7V3.5L18.5 9H13Z"/></svg>
									{formatWordCount(stats.words)}
								</span>
							)}
							{stats && (
								<span class="meta-item">
									<svg viewBox="0 0 24 24" aria-hidden="true" width="14" height="14"><path fill="currentColor" d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8Zm.5-13H11v6l5.2 3.1.8-1.3-4.5-2.7Z"/></svg>
									{stats.minutes} 分钟
								</span>
							)}
							{updatedDate && (
								<span class="meta-item updated">
									更新于 <FormattedDate date={updatedDate} />
								</span>
							)}
						</div>
						{tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => (
									<span class="tag">{tag}</span>
								))}
							</div>
						)}
					</header>
					<div class="prose">
						<slot />
					</div>
				</article>
				{hasTOC && <TOC headings={headings} />}
			</div>
		</main>
		<Footer />
		<style>
			main {
				width: 860px;
				padding-top: 2rem;
			}
			main.has-toc {
				width: 1120px;
			}
			.article-with-toc {
				display: block;
			}
			main.has-toc .article-with-toc {
				display: grid;
				grid-template-columns: minmax(0, 1fr) 220px;
				gap: 2.5rem;
				align-items: start;
			}
			article {
				background: var(--color-surface);
				border: 1px solid var(--color-border);
				border-radius: var(--radius-card);
				box-shadow: var(--shadow-card);
				padding: 2.5rem 2.5rem 2rem;
			}
			.post-head {
				margin-bottom: 2rem;
				padding-bottom: 1.5rem;
				border-bottom: 1px solid var(--color-border);
			}
			.meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem 1rem;
				color: var(--color-text-muted);
				font-size: 0.88rem;
			}
			.meta-item {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
			}
			.meta-item.updated {
				font-style: italic;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				margin-top: 0.85rem;
			}
			.tag {
				display: inline-flex;
				padding: 0.2rem 0.7rem;
				background: color-mix(in srgb, var(--color-accent-soft) 30%, transparent);
				color: var(--color-accent);
				border-radius: var(--radius-pill);
				font-size: 0.78rem;
				font-weight: 500;
			}
			.prose {
				color: var(--color-text);
				font-size: 1rem;
				line-height: 1.85;
			}
			.prose :global(h2) {
				margin-top: 2.25rem;
				margin-bottom: 0.75rem;
				font-size: 1.65rem;
				scroll-margin-top: 5rem;
			}
			.prose :global(h3) {
				margin-top: 1.75rem;
				margin-bottom: 0.5rem;
				font-size: 1.3rem;
				scroll-margin-top: 5rem;
			}
			.prose :global(h4) {
				scroll-margin-top: 5rem;
			}
			.prose :global(p) {
				margin: 0 0 1em;
			}
			.prose :global(a) {
				border-bottom: 1px dashed currentColor;
			}
			.prose :global(a:hover) {
				border-bottom-style: solid;
			}
			.prose :global(img) {
				border-radius: var(--radius-card);
				box-shadow: var(--shadow-card);
				margin: 1.5em auto;
			}

			@media (max-width: 1023px) {
				main {
					width: 760px;
					padding-top: 1.5rem;
				}
				.article-with-toc {
					display: block;
				}
				article {
					padding: 1.75rem 1.5rem;
				}
			}
			@media (max-width: 720px) {
				article {
					padding: 1.5rem 1.1rem;
				}
				.prose :global(h2) {
					font-size: 1.4rem;
				}
				.prose :global(h3) {
					font-size: 1.15rem;
				}
			}
		</style>
	</body>
</html>
