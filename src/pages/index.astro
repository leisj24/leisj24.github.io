---
import { getCollection } from 'astro:content';
import Banner from '../components/Banner.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import ProfileCard from '../components/ProfileCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { calcReadingStats } from '../utils/reading-time';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = allPosts.slice(0, 6).map((post) => ({
	post,
	stats: calcReadingStats(post.body ?? ''),
}));
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<Banner
			transition:name="page-banner"
			title="leisj24's Homepage"
			subtitle="USTC 本科生 · 学习轨迹与技术思考"
		/>
		<main>
			<div class="page-with-sidebar">
				<ProfileCard
					name="leisj24"
					tagline="USTC 本科生 · 这里是我的学习轨迹与技术思考。"
				/>
				<article>
					<header class="section-head">
						<h2>最新文章</h2>
						<a class="view-all" href="/blog">查看全部 →</a>
					</header>
					{
						recentPosts.length === 0 ? (
							<p class="empty">还没有文章，敬请期待。</p>
						) : (
							<div class="posts-grid">
								{recentPosts.map(({ post, stats }) => (
									<PostCard
										href={`/blog/${post.id}/`}
										title={post.data.title}
										pubDate={post.data.pubDate}
										description={post.data.description}
										tags={post.data.tags}
										words={stats.words}
										minutes={stats.minutes}
									/>
								))}
							</div>
						)
					}
				</article>
			</div>
		</main>
		<Footer />
		<style>
			main {
				width: 1120px;
				padding-top: 2rem;
			}
			.page-with-sidebar {
				display: grid;
				grid-template-columns: 280px minmax(0, 1fr);
				gap: 2rem;
				align-items: start;
			}
			.page-with-sidebar > :global(aside) {
				position: sticky;
				top: 5rem;
			}
			.section-head {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1.25rem;
			}
			.section-head h2 {
				margin: 0;
				font-size: 1.5rem;
			}
			.view-all {
				font-size: 0.95rem;
				color: var(--color-accent);
				font-weight: 500;
			}
			.posts-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
				gap: 1.25rem;
			}
			.empty {
				color: var(--color-text-muted);
				text-align: center;
				padding: 2rem 0;
			}

			@media (max-width: 1023px) {
				main {
					width: 760px;
					padding-top: 1.5rem;
				}
				.page-with-sidebar {
					display: flex;
					flex-direction: column;
					gap: 1.75rem;
				}
				.page-with-sidebar > :global(aside) {
					position: static;
					max-width: 480px;
					width: 100%;
					align-self: center;
				}
			}
		</style>
	</body>
</html>
