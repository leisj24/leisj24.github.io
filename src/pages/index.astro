---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>👋 Hi，我是 leisj24</h1>
			<p>
				我是 <a href="https://www.ustc.edu.cn/" target="_blank" rel="noopener">中国科学技术大学（USTC）</a> 的一名本科生，
				这里是我的个人主页，用来记录学习笔记、课程项目，以及一些对技术与世界的思考。
			</p>

			<h2>📚 最近在做什么</h2>
			<ul>
				<li>学习计算机科学与相关数学课程</li>
				<li>探索感兴趣的方向（算法 / 系统 / AI ……还在寻找）</li>
				<li>把读书、上课、做项目的笔记慢慢搬到博客上</li>
			</ul>

			<h2>✍️ 最新博客</h2>
			<p>
				去 <a href="/blog">博客页面</a> 看全部文章，
				或者去 <a href="/about">关于我</a> 了解更多。
			</p>

			<h2>📮 联系方式</h2>
			<p>
				欢迎通过 <a href="https://github.com/leisj24" target="_blank" rel="noopener">GitHub</a> 找到我，
				一起交流学习与项目。
			</p>
		</main>
		<Footer />
	</body>
</html>
